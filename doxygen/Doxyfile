# --- Project settings ---
PROJECT_NAME           = "DoxyTest
PROJECT_BRIEF          = "Automatic documentation generated by GitHub Actions"

# --- Input settings ---
# This is the folder Doxygen will look inside to find your code. 
# Common names are src, include, or just . (for the current directory)
INPUT                  = ./  
RECURSIVE              = YES   

# --- Output settings ---
GENERATE_HTML          = YES
HTML_OUTPUT            = html  
GENERATE_LATEX         = NO    

# --- Extraction settings ---
EXTRACT_ALL            = YES
